# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
KB_SECRET_KEY=change-me-to-a-random-string
KB_BASE_URL=https://kb.constantin.rocks
KB_DATA_DIR=data
KB_PORT=8000
# Max size in bytes for multipart uploads to _raw/ (default 26214400 = 25 MiB)
# KB_MAX_UPLOAD_BYTES=26214400
# Docker Compose only: external Traefik network (e.g. hosting_public if your stack prefixes project name)
# KB_TRAEFIK_NETWORK=traefik-net
